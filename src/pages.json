{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^plc-(.*)": "@/components/ladder/$1.vue",
      "^common-(.*)": "@/components/common/$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "PLC编程助手"
      }
    },
    {
      "path": "pages/projects/list",
      "style": {
        "navigationBarTitleText": "项目列表"
      }
    },
    {
      "path": "pages/editor/main",
      "style": {
        "navigationBarTitleText": "梯形图编程",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/monitor/main",
      "style": {
        "navigationBarTitleText": "在线监控"
      }
    },
    {
      "path": "pages/tools/main",
      "style": {
        "navigationBarTitleText": "工具"
      }
    },
    {
      "path": "pages/profile/main",
      "style": {
        "navigationBarTitleText": "我的"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "PLC编程助手",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#E8EEF2"
  },
  "tabBar": {
    "color": "#607D8B",
    "selectedColor": "#00BCD4",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/projects/list",
        "text": "项目",
        "iconPath": "static/tabs/project.png",
        "selectedIconPath": "static/tabs/project-active.png"
      },
      {
        "pagePath": "pages/editor/main",
        "text": "编程",
        "iconPath": "static/tabs/program.png",
        "selectedIconPath": "static/tabs/program-active.png"
      },
      {
        "pagePath": "pages/monitor/main",
        "text": "监控",
        "iconPath": "static/tabs/monitor.png",
        "selectedIconPath": "static/tabs/monitor-active.png"
      },
      {
        "pagePath": "pages/tools/main",
        "text": "工具",
        "iconPath": "static/tabs/tools.png",
        "selectedIconPath": "static/tabs/tools-active.png"
      },
      {
        "pagePath": "pages/profile/main",
        "text": "我的",
        "iconPath": "static/tabs/profile.png",
        "selectedIconPath": "static/tabs/profile-active.png"
      }
    ]
  }
}
